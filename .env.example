# Server
PORT=3000
MCP_BASE_URL=http://localhost:3000

# Provider: mock | duffel
FLIGHT_PROVIDER=mock

# Duffel
# API key prefix determines environment: duffel_test_xxx = sandbox, duffel_live_xxx = live
# DUFFEL_ENV is a safety label; set it to match your key.
DUFFEL_API_KEY=
DUFFEL_ENV=sandbox
DUFFEL_BASE_URL=https://api.duffel.com

# Duffel Links (booking checkout redirect URLs)
DUFFEL_LINKS_SUCCESS_URL=https://skyroute.dev/booking/success
DUFFEL_LINKS_FAILURE_URL=https://skyroute.dev/booking/failure
DUFFEL_LINKS_ABANDONMENT_URL=https://skyroute.dev/booking/abandoned

# Auth (leave empty to disable auth)
API_KEY=

# Defaults
DEFAULT_CURRENCY=USD
DEFAULT_LOCALE=en-US
DEFAULT_MAX_RESULTS=20
OFFER_CACHE_TTL_MS=1800000

# Public endpoint protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
